# ─── App ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGIN=*

# ─── Database (PostgreSQL) ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=whatsapp_commerce
DB_POOL_SIZE=50
DB_SYNCHRONIZE=false

# ─── Redis ─────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Session ───────────────────────────────────────────────────────────
SESSION_SECRET=change-me-in-production-use-strong-secret
SESSION_TTL=86400

# ─── WhatsApp Cloud API (Messaging) ───────────────────────────────────
# WHATSAPP_APP_SECRET must be the same value as META_APP_SECRET
WHATSAPP_API_VERSION=v21.0
WHATSAPP_API_URL=https://graph.facebook.com
WHATSAPP_APP_SECRET=your-app-secret
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_RATE_LIMIT_MAX=70
WHATSAPP_RATE_LIMIT_DURATION=1000

# ─── Meta Platform / Embedded Signup ──────────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_EMBEDDED_SIGNUP_CONFIG_ID=your_config_id
META_GRAPH_API_VERSION=v21.0
META_SYSTEM_USER_ID=your_system_user_id
META_SYSTEM_USER_TOKEN=your_system_user_token
# The Embedded Signup config (META_EMBEDDED_SIGNUP_CONFIG_ID) must be created in the
# Meta App Dashboard with the COEXISTENCE feature enabled so numbers stay live on the
# WhatsApp Business App + Cloud API. Share your line of credit with client WABAs in
# Meta Business Manager so conversations bill to YOUR account (Solution Partner billing).

# ─── Social Login / Signup (OAuth) ────────────────────────────────────
# Google: create an OAuth 2.0 Client (type: Web) in Google Cloud Console.
#   Authorized redirect URI: <OAUTH_CALLBACK_BASE_URL>/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Meta social login reuses META_APP_ID / META_APP_SECRET above. Enable the
# "Facebook Login" product on that app and add this redirect URI:
#   <OAUTH_CALLBACK_BASE_URL>/auth/oauth/meta/callback
# Public base URL of THIS backend (where providers redirect back to). No trailing slash.
OAUTH_CALLBACK_BASE_URL=https://api.yourdomain.com
# Public URL of the frontend SPA, where users land after login. No trailing slash.
FRONTEND_URL=https://app.yourdomain.com

# ─── Token Encryption (REQUIRED — no default, app will crash without it)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex').slice(0,32))"
TOKEN_ENCRYPTION_KEY=

# ─── AWS S3 / CDN ─────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=whatsapp-commerce-media
CLOUDFRONT_DOMAIN=cdn.yourapp.com

# ─── Queue (BullMQ Redis) ─────────────────────────────────────────────
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379

# ─── Razorpay (Payments) ──────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Inventory ─────────────────────────────────────────────────────────
RESERVATION_TTL_MINUTES=15

# ─── Admin Seed (initial super-admin account) ─────────────────────────
ADMIN_EMAIL=admin@wacommerce.in
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=Platform Admin

# ─── Observability (all optional) ─────────────────────────────────────
# Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# OpenTelemetry
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=whatsapp-commerce-api
