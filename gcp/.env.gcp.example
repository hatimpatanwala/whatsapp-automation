# ─── GCP Production Environment Variables ─────────────────────────────
# Copy this to .env.gcp and fill in your values
# Usage: docker compose -f gcp/docker-compose.gcp.yml --env-file .env.gcp up -d
# ───────────────────────────────────────────────────────────────────────

# ─── Database (REQUIRED) ──────────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_NAME=whatsapp_commerce
DB_POOL_SIZE=20

# ─── Redis ─────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ─── Session (REQUIRED) ───────────────────────────────────────────────
SESSION_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
SESSION_TTL=86400

# ─── CORS ──────────────────────────────────────────────────────────────
# Set to your domain. For initial setup, use * then restrict later
CORS_ORIGIN=http://YOUR_GCP_VM_IP,https://yourdomain.com

# ─── Token Encryption (REQUIRED) ──────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS

# ─── WhatsApp Cloud API ───────────────────────────────────────────────
WHATSAPP_API_VERSION=v21.0
WHATSAPP_API_URL=https://graph.facebook.com
WHATSAPP_APP_SECRET=your_app_secret
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_RATE_LIMIT_MAX=70
WHATSAPP_RATE_LIMIT_DURATION=1000

# ─── Meta Platform ────────────────────────────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_SYSTEM_USER_ID=your_system_user_id
META_SYSTEM_USER_TOKEN=your_system_user_token

# ─── AWS S3 ───────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET=whatsapp-commerce-media

# ─── Razorpay ─────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Admin Seed ────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@wacommerce.in
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
ADMIN_NAME=Platform Admin
