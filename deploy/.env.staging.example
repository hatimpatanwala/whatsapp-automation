# ─── STAGING env — derived from the PRODUCTION deploy/.env ──────────────────
#
# Goal: reuse ALL of prod's env values, overriding only what must differ so the
# two stacks stay isolated. Create the real file ON THE SERVER like this:
#
#   cp deploy/.env deploy/.env.staging
#   # then edit deploy/.env.staging and apply the overrides below
#
# The DB/Redis passwords may stay identical to prod (the staging Postgres/Redis
# are SEPARATE containers + volumes, so there is no collision). Keep
# TOKEN_ENCRYPTION_KEY identical to prod if you ever want to clone encrypted
# rows beyond super_admins; for super_admins alone (bcrypt) it isn't required.
#
# ── Overrides to apply in deploy/.env.staging (everything else = same as prod) ──

# Separate logical DB name (different container + volume regardless).
DB_NAME=whatsapp_commerce_staging

# Smaller pool for the test box.
DB_POOL_SIZE=10

# Point CORS + OAuth + frontend at the STAGING URLs (the frontend is published on
# host port 8081; the backend API on 127.0.0.1:3001). Use whatever public
# hostname/reverse-proxy you point at staging, e.g. a separate subdomain.
CORS_ORIGIN=https://staging.yourdomain.com
FRONTEND_URL=https://staging.yourdomain.com
OAUTH_CALLBACK_BASE_URL=https://staging-api.yourdomain.com

# (Optional) a distinct session secret so staging cookies don't collide with prod.
SESSION_SECRET=change-me-staging-only-secret

# Everything below is COPIED FROM PROD unchanged (do not blank these):
#   DB_USERNAME, DB_PASSWORD, REDIS_PASSWORD, TOKEN_ENCRYPTION_KEY,
#   WHATSAPP_APP_SECRET, WHATSAPP_VERIFY_TOKEN,
#   META_APP_ID, META_APP_SECRET, META_EMBEDDED_SIGNUP_CONFIG_ID,
#   META_SYSTEM_USER_ID, META_SYSTEM_USER_TOKEN,
#   AWS_*, S3_BUCKET, CLOUDFRONT_DOMAIN, RAZORPAY_*, SMTP_*, ADMIN_*
#
# Tip to copy prod values quickly (run on the server):
#   grep -E '^(DB_PASSWORD|REDIS_PASSWORD|TOKEN_ENCRYPTION_KEY|WHATSAPP_|META_|AWS_|S3_|CLOUDFRONT_|RAZORPAY_|SMTP_|ADMIN_)' deploy/.env
