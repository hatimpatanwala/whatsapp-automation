# ─── AWS EC2 Production Environment ───────────────────────────────────
# Copy this to .env and fill in real values
# Docker Compose reads this file — DB_HOST/REDIS_HOST are overridden
# by container names in docker-compose.yml, so keep them as-is here.
# ───────────────────────────────────────────────────────────────────────

# ─── App ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
API_PREFIX=api
CORS_ORIGIN=http://YOUR_EC2_IP_OR_DOMAIN

# ─── Database (PostgreSQL) ────────────────────────────────────────────
# DB_HOST is overridden to 'postgres' (container name) by docker-compose
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_NAME=whatsapp_commerce
DB_POOL_SIZE=20

# ─── Redis ─────────────────────────────────────────────────────────────
# REDIS_HOST is overridden to 'redis' (container name) by docker-compose
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ─── Session ───────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND
SESSION_TTL=86400

# ─── WhatsApp Cloud API ───────────────────────────────────────────────
WHATSAPP_API_VERSION=v21.0
WHATSAPP_API_URL=https://graph.facebook.com
WHATSAPP_APP_SECRET=your-app-secret
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_RATE_LIMIT_MAX=70
WHATSAPP_RATE_LIMIT_DURATION=1000

# ─── Meta Platform / Embedded Signup ──────────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_EMBEDDED_SIGNUP_CONFIG_ID=your_config_id
META_GRAPH_API_VERSION=v21.0
META_SYSTEM_USER_ID=your_system_user_id
META_SYSTEM_USER_TOKEN=your_system_user_token

# ─── Token Encryption (REQUIRED — app crashes without it) ────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex').slice(0,32))"
# Or: openssl rand -hex 16
TOKEN_ENCRYPTION_KEY=CHANGE_ME_GENERATE_32_CHAR_HEX

# ─── AWS S3 / CDN ─────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=whatsapp-commerce-media
CLOUDFRONT_DOMAIN=

# ─── SMTP / Email Verification ────────────────────────────────────────
# Required for email OTP verification during signup (production only).
# In development, OTP is static "123456" and logged to console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ─── Razorpay ─────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Inventory ─────────────────────────────────────────────────────────
RESERVATION_TTL_MINUTES=15

# ─── Admin Seed (initial super-admin) ─────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
ADMIN_NAME=Platform Admin

# ─── Observability (optional) ─────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
OTEL_ENABLED=false
